rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

   match /sellerOrders/{orderId} {
  allow read, write: if request.auth != null;

  match /items/{itemId} {
    allow read, write: if request.auth != null;
  }
}

    match /orderTimeline/{docId} {
      allow read, write: if request.auth != null;
    }

    match /urunler/{urunId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /chef_profiles/{chefId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

   match /sepetler/{cartId} {
  allow read, write: if request.auth != null;

  match /items/{itemId} {
    allow read, write: if request.auth != null;
  }
}

    match /sepet/{userId} {
      allow read, write: if request.auth != null;

      match /items/{itemId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}