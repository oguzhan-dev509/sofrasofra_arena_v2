rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid));
    }

function isRestaurantOwner(restaurantId) {
  return signedIn()
    && restaurantId is string
    && restaurantId.size() > 0
    && exists(
      /databases/$(database)/documents/restaurants/$(restaurantId)
    )
    && get(
      /databases/$(database)/documents/restaurants/$(restaurantId)
    ).data.ownerUid == request.auth.uid;
}
function restaurantOwnerCanUpdate() {
  return signedIn()
    && resource.data.ownerUid == request.auth.uid
    && request.resource.data.ownerUid == resource.data.ownerUid
    && request.resource.data.restaurantId == resource.data.restaurantId
    && request.resource.data.sellerId == resource.data.sellerId
    && !request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasAny([
        'ownerUid',
        'createdBy',
        'applicationId',
        'restaurantId',
        'sellerId',
        'membershipType',
        'packageType',
        'membershipStatus',
        'isFounder'
      ]);
}
    function protectedMembershipKeys() {
      return [
        'membershipType',
        'membershipStatus',
        'maxPhotoCount',
        'maxVideoCount',
        'canUseYoutube',
        'canBeFeatured',
        'canJoinMainShowcase',
        'featuredScope',
        'priorityScore',
        'badgeType',
        'isFeatured',
        'featureRank',
        'sellerMembershipType',
        'sellerBadgeType',
        'listingScore'
      ];
    }

    function hasProtectedKeysOnCreate() {
      return request.resource.data.keys().hasAny(protectedMembershipKeys());
    }

    function hasProtectedKeysOnUpdate() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(protectedMembershipKeys());
    }

    match /orders/{orderId} {
      allow read, write: if signedIn();
    }

   match /sellerOrders/{orderId} {
  // Müşteri yalnızca kendi UID'siyle sipariş oluşturabilir.
  allow create: if signedIn()
    && request.resource.data.userId == request.auth.uid
    && request.resource.data.saticiId is string
    && request.resource.data.saticiId.size() > 0;

  // Admin, sipariş müşterisi veya ilgili restoran sahibi okuyabilir.
  allow read: if isPlatformAdmin()
    || (
      signedIn()
      && resource.data.userId == request.auth.uid
    )
    || isRestaurantOwner(resource.data.saticiId);

  // Restoran sahibi yalnızca operasyonel durum alanlarını değiştirebilir.
  allow update: if isPlatformAdmin()
    || (
      isRestaurantOwner(resource.data.saticiId)
      && request.resource.data.userId == resource.data.userId
      && request.resource.data.saticiId == resource.data.saticiId
      && request.resource.data.sellerType == resource.data.sellerType
      && request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly([
  'status',
  'durum',
  'statusUpdatedAt',
  'updatedAt',
  'acceptedAt',
  'preparationMinutes',
  'estimatedReadyAt',
  'rejectedAt',
  'rejectionReason'
])
    );

  allow delete: if isPlatformAdmin();

  match /items/{itemId} {
    // Sipariş oluşturulurken aynı batch içindeki üst belgeyi kontrol eder.
    allow create: if signedIn()
      && getAfter(
        /databases/$(database)/documents/sellerOrders/$(orderId)
      ).data.userId == request.auth.uid;

    allow read: if isPlatformAdmin()
      || (
        signedIn()
        && get(
          /databases/$(database)/documents/sellerOrders/$(orderId)
        ).data.userId == request.auth.uid
      )
      || isRestaurantOwner(
        get(
          /databases/$(database)/documents/sellerOrders/$(orderId)
        ).data.saticiId
      );

    allow update, delete: if isPlatformAdmin();
  }
}

    match /orderTimeline/{docId} {
      allow read, write: if signedIn();
    }

    match /urunler/{urunId} {
  allow read: if true;

  allow create: if signedIn()
    && (
      isPlatformAdmin()
      || !hasProtectedKeysOnCreate()
    );

  allow update: if signedIn()
    && (
      isPlatformAdmin()
      || !hasProtectedKeysOnUpdate()
    );

  allow delete: if isPlatformAdmin();
}

    match /chef_profiles/{chefId} {
      allow read: if true;

      allow create: if signedIn()
        && (
          isPlatformAdmin()
          || (
            request.auth.uid == chefId
            && !hasProtectedKeysOnCreate()
          )
        );

      allow update: if signedIn()
        && (
          isPlatformAdmin()
          || (
            request.auth.uid == chefId
            && !hasProtectedKeysOnUpdate()
          )
        );

      allow delete: if isPlatformAdmin();
    }

    match /sellers/{sellerId} {
      allow read: if true;

      allow create: if signedIn()
        && (
          isPlatformAdmin()
          || (
            request.auth.uid == sellerId
            && !hasProtectedKeysOnCreate()
          )
        );

      allow update: if signedIn()
        && (
          isPlatformAdmin()
          || (
            request.auth.uid == sellerId
            && !hasProtectedKeysOnUpdate()
          )
        );
        
         allow delete: if isPlatformAdmin();

     match /addon_items/{addonId} {
  allow read: if true;

  allow create, update, delete: if signedIn()
    && (
      isPlatformAdmin()
      || get(
        /databases/$(database)/documents/sellers/$(sellerId)
      ).data.ownerUid == request.auth.uid
    );
}
    }

  match /sepetler/{cartId} {
  allow read, write: if signedIn();

  match /items/{itemId} {
    allow read, write: if signedIn();
  }
}

  match /sepet/{userId} {
  allow read, write: if signedIn();

  match /items/{itemId} {
    allow read, write: if signedIn();
  }
}
match /customer_delivery_profiles/{userId} {
  allow read: if signedIn()
    && request.auth.uid == userId;

  allow create: if signedIn()
    && request.auth.uid == userId
    && request.resource.data.userId == request.auth.uid;

  allow update: if signedIn()
    && request.auth.uid == userId
    && resource.data.userId == request.auth.uid
    && request.resource.data.userId == request.auth.uid;

  allow delete: if signedIn()
    && request.auth.uid == userId;
}
match /appInstallations/{installId} {
  allow create: if signedIn()
    && request.resource.data.installId == installId
    && request.resource.data.userUid == request.auth.uid;

  allow get: if signedIn()
    && (
      isPlatformAdmin()
      || resource.data.userUid == request.auth.uid
    );

  allow list: if isPlatformAdmin();

  allow update: if signedIn()
    && (
      isPlatformAdmin()
      || (
        resource.data.userUid == request.auth.uid
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.installId == installId
        && request.resource.data.installId == resource.data.installId
      )
    );

  allow delete: if isPlatformAdmin();
}
match /producer_applications/{applicationId} {
  allow read: if isPlatformAdmin()
    || (
      signedIn()
      && resource.data.userId == request.auth.uid
    );

  // Başvurular uygulamadan doğrudan değil, Cloud Function üzerinden yazılıyor.
  allow create: if false;

  allow update, delete: if isPlatformAdmin();
}
match /neighborhood_coach_applications/{applicationId} {
  // Anonim veya kayıtlı kullanıcı yalnızca bekleyen,
  // hukuki onay verilmiş gerçek bir Mahalle Koçu başvurusu oluşturabilir.
  allow create: if signedIn()
    && request.resource.data.applicationType == 'neighborhood_coach'
    && request.resource.data.status == 'pending'
    && request.resource.data.legalAccepted == true
    && request.resource.data.fullName is string
    && request.resource.data.fullName.size() > 1
    && request.resource.data.phone is string
    && request.resource.data.phone.size() > 5;

  // Başvuruları ve IBAN gibi kişisel verileri yalnızca platform yöneticisi okuyabilir.
  allow read: if isPlatformAdmin();

  // Onay, ret ve inceleme işlemleri yalnızca platform yöneticisine açıktır.
  allow update, delete: if isPlatformAdmin();
}
match /user_notifications/{notificationId} {
  // Kullanıcı yalnızca kendisine ait bildirimleri okuyabilir.
  allow read: if signedIn()
    && resource.data.userId == request.auth.uid;

  // Bildirim yalnızca platform yöneticisi tarafından oluşturulabilir.
  allow create: if isPlatformAdmin()
    && request.resource.data.userId is string
    && request.resource.data.userId.size() > 0;

  // Kullanıcı yalnızca okundu bilgilerini değiştirebilir.
  allow update: if signedIn()
    && resource.data.userId == request.auth.uid
    && request.resource.data.userId == resource.data.userId
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        'isRead',
        'readAt',
        'updatedAt'
      ]);

  allow delete: if isPlatformAdmin();
}
match /restaurants/{restaurantId} {
  allow read: if true;

  allow create: if isPlatformAdmin()
    || (
      signedIn()
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdBy == request.auth.uid
      && request.resource.data.restaurantId == restaurantId
      && request.resource.data.sellerId == restaurantId
    );

  allow update: if isPlatformAdmin()
    || restaurantOwnerCanUpdate();

  // Kalıcı silme şimdilik yalnızca platform yöneticisinde kalsın.
  allow delete: if isPlatformAdmin();

  match /menu_items/{itemId} {
    allow read: if true;

    allow create, update, delete: if isPlatformAdmin()
      || isRestaurantOwner(restaurantId);
  }

  match /reviews/{reviewId} {
    allow read: if true;

    allow create: if signedIn()
      && request.resource.data.comment is string
      && request.resource.data.comment.size() > 0
      && request.resource.data.comment.size() <= 1000
      && request.resource.data.status == "pending"
      && request.resource.data.source == "restaurant_detail_page";

    allow update, delete: if isPlatformAdmin();
  }
}
match /chef_signature_dishes/{dishId} {
  allow read: if true;
  allow create, update, delete: if isPlatformAdmin();
}
match /blog_yazilari/{postId} {
  allow read: if true;
  allow create, update, delete: if isPlatformAdmin();
}

match /radyo_yayinlari/{broadcastId} {
  allow read: if true;
  allow create, update, delete: if isPlatformAdmin();
}
match /home_showcase_items/{itemId} {
  allow read: if true;
  allow create, update, delete: if isPlatformAdmin();
}
match /users/{userId} {
  match /favorites/{favoriteId} {
    // Kullanıcı yalnızca kendi favorilerini okuyabilir.
    allow read: if signedIn()
      && request.auth.uid == userId;

    // Kullanıcı yalnızca kendi adına favori oluşturabilir.
    allow create: if signedIn()
      && request.auth.uid == userId
      && request.resource.data.userId == request.auth.uid
      && request.resource.data.favoriteId == favoriteId
      && request.resource.data.productId is string
      && request.resource.data.productId.size() > 0
      && request.resource.data.sellerType is string
      && request.resource.data.sellerType.size() > 0;

    // Kullanıcı yalnızca kendi favori kaydını güncelleyebilir.
    allow update: if signedIn()
      && request.auth.uid == userId
      && resource.data.userId == request.auth.uid
      && request.resource.data.userId == request.auth.uid
      && request.resource.data.favoriteId == favoriteId;

    // Kullanıcı yalnızca kendi favorisini silebilir.
    allow delete: if signedIn()
      && request.auth.uid == userId
      && resource.data.userId == request.auth.uid;
  }
}
    // Tanımlanmamış koleksiyonlar için vitrin/liste okumasını açık tutar.
    // Yazma kapalıdır. Premium/Pro koruması yukarıdaki özel bloklarda devam eder.
    match /couriers/{courierId} {
  allow read: if signedIn();
  allow create, update, delete: if isPlatformAdmin();
}
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}